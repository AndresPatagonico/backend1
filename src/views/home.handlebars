<h1>Catálogo de Productos</h1>
<ul>
    {{#each products}}
        <li>
            <strong>{{this.title}}</strong> - ${{this.price}} 
            <br>
            <small>Código: {{this.code}} | Categoría: {{this.category}}</small>
        </li>
    {{else}}
        <p>No hay productos registrados aún.</p>
    {{/each}}
</ul>